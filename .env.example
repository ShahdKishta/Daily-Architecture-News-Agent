# Google Gemini API key (used for Gemini + Google Search grounding tool)
GEMINI_API_KEY=your-gemini-api-key-here

# Resend API key (used to send the daily email report)
RESEND_API_KEY=re_your-key-here

# Supabase project URL (public, safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (SERVER ONLY - never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: secret used to authorize calls to /api/run-agent (e.g. from Vercel Cron)
CRON_SECRET=your-cron-secret-here
