# Google Gemini API key (used for Gemini + Google Search grounding tool)
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram bot token (used to deliver the daily digest via Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Supabase project URL (public, safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (SERVER ONLY - never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Required by /api/cron: the external hourly scheduler must send this as
# "Authorization: Bearer <CRON_SECRET>", or it gets a 401. Also optionally
# gates GET /api/run-agent the same way (falls back to open if unset there).
CRON_SECRET=your-cron-secret-here
